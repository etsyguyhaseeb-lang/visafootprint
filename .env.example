# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Social Media API Keys (optional — scrapers work without these) ─────────────
TWITTER_BEARER_TOKEN=
YOUTUBE_API_KEY=

# ── Paid scraper fallback (leave blank to use free scrapers only) ─────────────
USE_PAID_SCRAPERS=false
SCRAPECREATORS_API_KEY=
APIFY_API_TOKEN=

# ── CORS — set to your production frontend URL ────────────────────────────────
# Single URL:
FRONTEND_URL=https://visafootprint.com
# Or comma-separated for multiple origins:
CORS_ORIGINS=https://visafootprint.com,https://www.visafootprint.com

# ── Storage paths (defaults work fine, change only if needed) ─────────────────
OUTPUT_DIR=.tmp
DB_PATH=.tmp/screening.db
REPORTS_DIR=.tmp/reports
